# ═══════════════════════════════════════════════════════════════════
# Clario - Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# All values are required unless marked [optional].

# ─── App ──────────────────────────────────────────────────────────
# Public URL of your app (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────
# Find these in your Supabase project dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# ⚠️ CRITICAL: Never prefix with NEXT_PUBLIC_. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Groq AI ──────────────────────────────────────────────────────
# Used for all AI features (summarization, chat, remix, insights).
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ─── Stripe ───────────────────────────────────────────────────────
# Find these in Stripe Dashboard → Developers → API keys.
# Use test keys (sk_test_ / pk_test_) for development.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
# From Stripe Dashboard → Developers → Webhooks → Your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_secret
# Default price ID for checkout (create products/prices in Stripe Dashboard first)
NEXT_PUBLIC_STRIPE_PRICE_ID=price_your_pro_monthly_id
# Individual price IDs for server-side checkout creation (create-checkout route)
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_your_pro_annual_id

# ─── Admin ────────────────────────────────────────────────────────
# Email of admin user who bypasses usage limits for testing.
ADMIN_EMAIL=admin@example.com

# ─── Rate Limiting ────────────────────────────────────────────────
# Auth endpoints (sign-in, sign-up, password reset): max requests per window.
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900
# General API endpoints: max requests per window.
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60

# ─── Cron [optional] ─────────────────────────────────────────────
# For the keep-alive endpoint used by Vercel Cron Jobs.
CRON_SECRET=your-cron-secret

# ─── Notes ────────────────────────────────────────────────────────
# YouTube transcripts are fetched natively via youtubei.js.
# No TRANSCRIPT_SERVICE_URL or ASSEMBLYAI_API_KEY needed.
