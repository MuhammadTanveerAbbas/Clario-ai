# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Supabase
# Get from: https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─────────────────────────────────────────────
# Groq AI
# Get from: https://console.groq.com/keys
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ─────────────────────────────────────────────
# Stripe Payments
# Get from: https://dashboard.stripe.com/test/apikeys
# ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Price IDs  create these in your Stripe dashboard
NEXT_PUBLIC_STRIPE_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id
STRIPE_PRICE_PRO_ANNUAL=price_your_pro_annual_price_id

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@example.com

# ─────────────────────────────────────────────
# Sentry Error Monitoring (Optional)
# Get from: https://sentry.io/settings/projects/
# ─────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────
# PostHog Analytics (Optional)
# Get from: https://posthog.com/project/settings
# US region: https://us.posthog.com
# EU region: https://eu.posthog.com
# ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────
# Rate Limiting (Optional  defaults shown)
# ─────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60
